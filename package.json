{
  "name": "sy-translator",
  "displayName": "Doc Translator",
  "description": "Translate English .md and .txt documents to Chinese using AI models",
  "version": "0.1.1",
  "publisher": "yesu666",
  "repository": {
    "type": "git",
    "url": "https://github.com/ye1su/sy-translate.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:sy-translator.translate",
    "onCommand:sy-translator.configure"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sy-translator.translate",
        "title": "Translate to Chinese"
      },
      {
        "command": "sy-translator.configure",
        "title": "Configure sy-translator"
      }
    ],
    "configuration": {
      "title": "sy-translator",
      "properties": {
        "sy-translator.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for translation service"
        },
        "sy-translator.apiEndpoint": {
          "type": "string",
          "default": "",
          "description": "API endpoint URL (e.g., https://api.minimaxi.com/v1)"
        },
        "sy-translator.model": {
          "type": "string",
          "default": "",
          "description": "Model name for translation"
        }
      }
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.3.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "openai": "^6.34.0"
  }
}
